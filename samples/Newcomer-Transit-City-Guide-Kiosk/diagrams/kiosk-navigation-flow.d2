  }
}

home -> transit: "enter transit"
transit -> transit_routes
transit -> plan_trip
transit -> fare

home -> poi: "browse city guide"
home -> emergency: "request assistance"
emergency -> help_request

taskbar -> home: "home"
taskbar -> language: "language"
taskbar -> transit: {
  style: {
    stroke-dash: 4
  }
}
taskbar -> poi: {
  style: {
    stroke-dash: 4
  }
}
taskbar -> emergency: {
  style: {
    stroke-dash: 4
  }
}
