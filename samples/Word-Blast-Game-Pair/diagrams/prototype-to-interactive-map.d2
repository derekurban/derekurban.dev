direction: right

prototype: {
  label: "Prototype Repo"
  style: {
    fill: "#F5F8FC"
    stroke: "#8A97A8"
  }

  proto_layout: {
    label: "Layout + Visual Mockup"
    shape: rectangle
    style: {
      fill: "#EEF3F8"
      stroke: "#8A97A8"
      font-color: "#243447"
    }
  }

  proto_classes: {
    label: "Player / Session / Game\nMethod Stubs"
    shape: rectangle
    style: {
      fill: "#EEF3F8"
      stroke: "#8A97A8"
      font-color: "#243447"
    }
  }

  proto_placeholders: {
    label: "Sample HTML Cards +\nComment-Only Behavior"
    shape: rectangle
    style: {
      fill: "#EEF3F8"
      stroke: "#8A97A8"
      font-color: "#243447"
    }
  }
}

interactive: {
  label: "Interactive Repo"
  style: {
    fill: "#F5F8FC"
    stroke: "#8A97A8"
  }

  live_state: {
    label: "Live Game State"
    shape: rectangle
    style: {
      fill: "#DFF1F7"
      stroke: "#3E7D8D"
      font-color: "#0E2B32"
    }
  }

  live_ui: {
    label: "Timers, Input Rules,\nDOM Rendering"
    shape: rectangle
    style: {
      fill: "#DFF1F7"
      stroke: "#3E7D8D"
      font-color: "#0E2B32"
    }
  }

  live_api: {
    label: "WordsAPI + OpenAI\nBrowser Integrations"
    shape: rectangle
    style: {
      fill: "#F8ECD7"
      stroke: "#B98A2E"
      font-color: "#4A3410"
    }
  }

  live_results: {
    label: "Previous Match Summary\nand Intermission Updates"
    shape: rectangle
    style: {
      fill: "#E8F4E7"
      stroke: "#5C8E58"
      font-color: "#19381A"
    }
  }
}

prototype.proto_layout -> interactive.live_ui: "implemented"
prototype.proto_classes -> interactive.live_state: "executed"
prototype.proto_placeholders -> interactive.live_results: "replaced"
prototype.proto_classes -> interactive.live_api: {
  label: "extended"
  style: {
    stroke-dash: 4
  }
}
